{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "if": "Bash(git *)",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/precommit-hook.mjs\"",
            "timeout": 120,
            "statusMessage": "pre-commit: lint · build · test"
          }
        ]
      }
    ]
  }
}
